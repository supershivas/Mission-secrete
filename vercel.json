{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/tv", "destination": "/tv.html" },
    { "source": "/livret", "destination": "/livret.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
